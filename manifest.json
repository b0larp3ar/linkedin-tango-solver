{
  "manifest_version": 3,

  "name": "LinkedIn Tango Solver",

  "version": "1.0",

  "permissions": [
    "activeTab"
  ],

  "host_permissions": [
    "https://www.linkedin.com/games/tango/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/games/tango/*"
      ],

      "js": [
        "main.js"
      ]
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}